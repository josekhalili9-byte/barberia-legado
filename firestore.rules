rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email == "josekhalili9@gmail.com" &&
        request.auth.token.email_verified == true;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidService() {
      return hasOnlyAllowedFields(['name', 'description', 'price', 'order']) &&
             isValidString('name', 1, 100) &&
             isValidString('description', 0, 500) &&
             request.resource.data.price is number && request.resource.data.price >= 0 &&
             request.resource.data.order is number;
    }

    function isValidGalleryImage() {
      return hasOnlyAllowedFields(['url', 'createdAt']) &&
             isValidString('url', 1, 1000000) && // Allow large base64 strings
             request.resource.data.createdAt is number;
    }

    function isValidAppointment() {
      return hasOnlyAllowedFields(['name', 'service', 'date', 'time', 'status', 'createdAt']) &&
             isValidString('name', 1, 100) &&
             isValidString('service', 1, 100) &&
             isValidString('date', 1, 20) &&
             isValidString('time', 1, 20) &&
             request.resource.data.status in ['pending', 'confirmed', 'rejected'] &&
             request.resource.data.createdAt is number;
    }

    function isValidReview() {
      return hasOnlyAllowedFields(['name', 'rating', 'comment', 'date', 'createdAt']) &&
             isValidString('name', 1, 100) &&
             request.resource.data.rating is number &&
             request.resource.data.rating >= 1 && request.resource.data.rating <= 5 &&
             isValidString('comment', 1, 1000) &&
             isValidString('date', 1, 20) &&
             request.resource.data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidService();
      allow delete: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidGalleryImage();
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin();
      allow create: if isValidAppointment() && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidAppointment();
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview();
      allow update: if isAdmin() && isValidReview();
      allow delete: if isAdmin();
    }
  }
}
